# DM Claude Configuration
#
# AI Provider Selection (optional, default: auto)
# Options:
#   - auto: автоматический выбор (API если есть ключ, иначе SDK)
#   - api: Anthropic API (требует ANTHROPIC_API_KEY)
#   - sdk: Claude SDK (требует подписку Claude Max/Pro, НЕ требует API ключ)
AI_PROVIDER=auto

# Anthropic API Key (требуется только для AI_PROVIDER=api)
# Получите ключ на: https://console.anthropic.com/
# Если используете AI_PROVIDER=sdk, этот ключ не нужен
ANTHROPIC_API_KEY=your_api_key_here

# Campaign Settings
DEFAULT_CAMPAIGN_NAME="My Campaign"
DEFAULT_STARTING_LOCATION="Thornwick"

# Optional: Discord webhook for session logging
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
