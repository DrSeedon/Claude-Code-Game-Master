{
  "id": "firearms-combat",
  "name": "Firearms Combat System",
  "version": "2.0.0",
  "author": "DM System Core",
  "description": "Automated firearms combat resolver with penetration mechanics, RPM simulation, and fire mode support for modern/STALKER campaigns",
  "category": "combat",
  "genre_tags": [
    "survival",
    "modern",
    "scifi",
    "horror"
  ],
  "tags": [
    "firearms",
    "combat",
    "ballistics",
    "stalker",
    "modern"
  ],
  "enabled_by_default": false,
  "dependencies": [],
  "optional_dependencies": [],
  "incompatible_with": [],
  "middleware": [],
  "features": [
    "Duration-based single, burst, and full-auto fire modes",
    "Separate physical ammo expenditure and bounded salvo resolution",
    "Magazine capacity and reload signaling",
    "Penetration vs Protection damage scaling",
    "Subclass bonuses (sharpshooter)",
    "Margin-based multi-bullet hits with bounded critical damage",
    "Multi-target distribution (full-auto)",
    "Auto XP tracking",
    "Auto ammo deduction via WorldGraph inventory",
    "Test mode for dry runs"
  ],
  "adds_to_core": {
    "tools": [
      "dm-combat.sh"
    ],
    "commands": {
      "dm-combat.sh resolve": "Resolve firearms combat with auto-damage calculation"
    },
    "data_fields": {
      "campaign_rules": {
        "firearms_system": {
          "weapons": {
            "AK-74": {
              "damage": "2d8+2",
              "pen": 6,
              "rpm": 650,
              "ammo_type": "5.45x39mm"
            }
          },
          "fire_modes": {
            "burst": {
              "duration_seconds": 1,
              "max_salvos_per_target": 3,
              "penalty_per_salvo": -2
            },
            "full_auto": {
              "duration_seconds": 3,
              "max_salvos_per_target": 6,
              "penalty_per_salvo": -2
            }
          }
        }
      }
    }
  },
  "use_cases": [
    "STALKER campaigns with Freedom/Duty firefights",
    "Fallout-style wasteland combat",
    "Modern military operations",
    "Cyberpunk gunfights",
    "Zombie apocalypse firearms survival"
  ],
  "architecture": "Standalone tool. DM calls dm-combat.sh resolve when firearms combat occurs. No middleware — does not intercept CORE tools.",
  "replaces": []
}
