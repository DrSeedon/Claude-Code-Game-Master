#!/bin/bash
# custom-stats post-hook for dm-consequence.sh

ACTION="$1"
[ "$ACTION" != "check" ] && exit 0

_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
while [ ! -d "$_dir/.git" ] && [ "$_dir" != "/" ]; do _dir="$(dirname "$_dir")"; done

cd "$_dir"
uv run python lib/world_graph.py consequence-check 2>/dev/null
