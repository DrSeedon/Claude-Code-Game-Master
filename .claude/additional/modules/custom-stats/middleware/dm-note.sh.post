#!/bin/bash
# action-tracker post-hook for dm-note.sh
MODULE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
_dir="$MODULE_DIR"
while [ ! -d "$_dir/.git" ] && [ "$_dir" != "/" ]; do _dir="$(dirname "$_dir")"; done
PROJECT_ROOT="$_dir"

CATEGORY="$1"
shift
DETAIL="$*"

cd "$PROJECT_ROOT"
uv run python "$MODULE_DIR/lib/action_tracker.py" log "note" "[$CATEGORY] $DETAIL" "dm-note.sh" 2>/dev/null
