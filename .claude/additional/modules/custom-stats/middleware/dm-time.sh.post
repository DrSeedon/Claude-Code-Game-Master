#!/bin/bash
# custom-stats post-hook for dm-time.sh
# Ticks custom stats, production, expenses, income, consequences via WorldGraph.

MODULE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
_dir="$MODULE_DIR"
while [ ! -d "$_dir/.git" ] && [ "$_dir" != "/" ]; do _dir="$(dirname "$_dir")"; done
PROJECT_ROOT="$_dir"

shift 2 2>/dev/null || shift $#
shift 2 2>/dev/null || shift $#

ELAPSED=0
TICK_ARGS=()

prev=""
for arg in "$@"; do
    if [ "$prev" = "--elapsed" ]; then
        ELAPSED="$arg"
        TICK_ARGS+=("--elapsed" "$arg")
    fi
    if [ "$arg" = "--sleeping" ]; then
        TICK_ARGS+=("--sleeping")
    fi
    prev="$arg"
done

if [ "$ELAPSED" = "0" ] || [ -z "$ELAPSED" ]; then
    exit 0
fi

cd "$PROJECT_ROOT"
uv run python lib/world_graph.py tick "${TICK_ARGS[@]}"
