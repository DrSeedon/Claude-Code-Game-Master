#!/bin/bash
# custom-stats post-hook for dm-time.sh
# Thin wrapper — all logic in survival_engine.py time-post-hook
#
# CORE calls: dispatch_middleware_post "dm-time.sh" "$1" "$2" "$@"
# After shift in dispatch: $1=time_of_day $2=date $3=time_of_day(dup) $4=date(dup) $5+=flags
# We use $2 (date) and extract flags from $5+

MODULE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
_dir="$MODULE_DIR"
while [ ! -d "$_dir/.git" ] && [ "$_dir" != "/" ]; do _dir="$(dirname "$_dir")"; done
PROJECT_ROOT="$_dir"

TIME_LABEL="$1 $2"
DATE="$2"
shift 4 2>/dev/null || shift $#

FILTERED_ARGS=()
for arg in "$@"; do
    case "$arg" in --resolve-actions) ;; *) FILTERED_ARGS+=("$arg") ;; esac
done

cd "$PROJECT_ROOT"
uv run python "$MODULE_DIR/lib/survival_engine.py" time-post-hook "$DATE" "${FILTERED_ARGS[@]}"

RESOLVE=false
ELAPSED=0
prev=""
for arg in "$@"; do
    if [ "$arg" = "--resolve-actions" ]; then
        RESOLVE=true
    fi
    if [ "$prev" = "--elapsed" ]; then
        ELAPSED="$arg"
    fi
    prev="$arg"
done

if [ "$RESOLVE" = true ]; then
    uv run python "$MODULE_DIR/lib/action_tracker.py" resolve "$ELAPSED" "$TIME_LABEL" 2>/dev/null
fi
